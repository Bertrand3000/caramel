<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>Tous les bons de livraison</title>
<style>
  body {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 10pt;
    color: #1a1a1a;
    margin: 0;
    padding: 0;
  }
  .page {
    padding: 12mm 18mm 10mm 18mm;
  }
  h1 {
    font-size: 13pt;
    font-weight: bold;
    text-align: center;
    margin: 0 0 6mm 0;
    border-bottom: 2px solid #1a1a1a;
    padding-bottom: 3mm;
  }
  .body-text {
    font-size: 10pt;
    line-height: 1.5;
    margin-bottom: 3mm;
  }
  .field-value {
    display: inline-block;
    border-bottom: 1px solid #1a1a1a;
    min-width: 100mm;
    margin-left: 2mm;
    padding-bottom: 0.5mm;
    font-weight: bold;
    vertical-align: bottom;
  }
  .field-blank {
    border-bottom: 1px solid #1a1a1a;
    display: inline-block;
    min-width: 100mm;
    margin-left: 2mm;
    height: 4.5mm;
    vertical-align: bottom;
  }
  .biens-table {
    width: 100%;
    border-collapse: collapse;
    margin: 2mm 0 3mm 0;
    font-size: 9.5pt;
  }
  .biens-table th {
    background: #f0f0f0;
    border: 1px solid #aaa;
    padding: 1.5mm 2.5mm;
    text-align: left;
    font-size: 9pt;
  }
  .biens-table td {
    border: 1px solid #ccc;
    padding: 1.5mm 2.5mm;
  }
  .clauses {
    margin: 2mm 0 2mm 0;
  }
  .clause-item {
    font-size: 10pt;
    line-height: 1.45;
    margin-bottom: 1.5mm;
    padding-left: 4mm;
    position: relative;
  }
  .clause-item::before {
    content: "–";
    position: absolute;
    left: 0;
  }
  .lieu-date-signatures {
    width: 100%;
    margin-top: 5mm;
  }
  .lieu-date-signatures td {
    vertical-align: top;
    padding: 0;
  }
  .lieu-date-col {
    width: 35%;
    padding-right: 4mm;
  }
  .sig-col {
    width: 32.5%;
    padding: 0 2mm;
    text-align: center;
  }
  .lieu-date-line {
    font-size: 10pt;
    line-height: 2;
  }
  .signature-label {
    font-size: 9pt;
    font-weight: bold;
    margin-bottom: 1.5mm;
    text-align: center;
  }
  .signature-box {
    border: 1px solid #aaa;
    height: 28mm;
    margin-top: 1mm;
  }
  .footer {
    margin-top: 4mm;
    font-size: 7pt;
    color: #aaa;
    border-top: 1px solid #ddd;
    padding-top: 1.5mm;
    text-align: center;
  }
  .document-break {
    page-break-after: always;
  }
</style>
</head>
<body>
{% for commande in commandes %}
  {% include 'logistique/pdf/partials/bon_livraison_page.html.twig' with { commande: commande } only %}
  {% if not loop.last %}
    <div class="document-break"></div>
  {% endif %}
{% endfor %}
</body>
</html>
