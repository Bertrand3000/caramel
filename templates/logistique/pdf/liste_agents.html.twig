<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>Liste agents {{ jour.date|date('d/m/Y') }}</title>
<style>
  body {
    font-family: Helvetica, Arial, sans-serif;
    font-size: 10pt;
    color: #1a1a1a;
    margin: 0;
    padding: 16mm;
  }
  h1 {
    margin: 0 0 4mm 0;
    font-size: 16pt;
  }
  .meta {
    margin: 0 0 8mm 0;
    color: #555;
    font-size: 9pt;
  }
  h2 {
    margin: 7mm 0 3mm 0;
    font-size: 11pt;
    border-bottom: 1px solid #bbb;
    padding-bottom: 1.5mm;
  }
  table {
    width: 100%;
    border-collapse: collapse;
  }
  th, td {
    border: 1px solid #d0d0d0;
    padding: 2mm 3mm;
    text-align: left;
  }
  th {
    background: #f2f2f2;
  }
  .page-break {
    page-break-after: always;
  }
</style>
</head>
<body>
  <h1>Liste agents</h1>
  <p class="meta">
    Jour de livraison : <strong>{{ jour.date|date('d/m/Y') }}</strong> ·
    {{ commandes|length }} agent(s)
  </p>

  {% set grouped = {} %}
  {% for commande in commandes %}
    {% set slot = commande.creneau ? commande.creneau.heureDebut|date('H:i') ~ ' - ' ~ commande.creneau.heureFin|date('H:i') : 'Sans créneau' %}
    {% set existing = grouped[slot] is defined ? grouped[slot] : [] %}
    {% set grouped = grouped|merge({ (slot): existing|merge([commande]) }) %}
  {% endfor %}

  {% for slot, slotCommandes in grouped %}
    <h2>Créneau {{ slot }}</h2>
    <table>
      <thead>
        <tr>
          <th>Nom</th>
          <th>Prénom</th>
          <th>Numéro agent</th>
        </tr>
      </thead>
      <tbody>
        {% for commande in slotCommandes %}
          <tr>
            <td>{{ commande.nom ?: '—' }}</td>
            <td>{{ commande.prenom ?: '—' }}</td>
            <td>{{ commande.numeroAgent ?: '—' }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>

    {% if loop.index is divisible by(2) and not loop.last %}
      <div class="page-break"></div>
    {% endif %}
  {% endfor %}
</body>
</html>
