{% extends 'base.html.twig' %}

{% block title %}Créneaux{% endblock %}

{% block body %}
    <main class="container py-4">
        <h1 class="h3 mb-3">Finalisation de la commande</h1>

        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ type == 'error' ? 'danger' : type }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        {% if creneaux is empty %}
            <div class="alert alert-light border">Aucun créneau disponible.</div>
        {% else %}
            <p class="alert alert-info">Vous avez dix minutes pour finaliser la commande sur cet écran.</p>
            <form method="post" action="{{ path('checkout_confirmer') }}" id="checkout-form">
                <section class="card mb-4">
                    <div class="card-body">
                        <h2 class="h5 mb-3">Vos informations</h2>
                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label class="form-label" for="checkout-nom">Nom</label>
                                <input class="form-control" id="checkout-nom" type="text" name="nom" maxlength="120" required>
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label" for="checkout-prenom">Prénom</label>
                                <input class="form-control" id="checkout-prenom" type="text" name="prenom" maxlength="120" required>
                            </div>
                            {% set user_roles = app.user ? app.user.roles : [] %}
                            {% set showNumeroAgent = false %}
                            {% if 'ROLE_ADMIN' not in user_roles and 'ROLE_PARTENAIRE' not in user_roles %}
                                {% if 'ROLE_AGENT' in user_roles or 'ROLE_TELETRAVAILLEUR' in user_roles %}
                                    {% set showNumeroAgent = true %}
                                {% endif %}
                            {% endif %}
                            {% if showNumeroAgent %}
                            <div class="col-12 col-md-6">
                                <label class="form-label" for="checkout-numero-agent">Numéro d'agent</label>
                                <input class="form-control" id="checkout-numero-agent" type="text" name="numeroAgent" inputmode="numeric" pattern="\d{5}" maxlength="5" required>
                            </div>
                            {% endif %}
                        </div>
                    </div>
                </section>

                {% set user_roles = app.user ? app.user.roles : [] %}
                {% set showCreneau = false %}
                {% if 'ROLE_ADMIN' not in user_roles and 'ROLE_PARTENAIRE' not in user_roles %}
                    {% if 'ROLE_AGENT' in user_roles or 'ROLE_TELETRAVAILLEUR' in user_roles %}
                        {% set showCreneau = true %}
                    {% endif %}
                {% endif %}
                {% if showCreneau %}
                <h2 class="h5 mb-3">Choisissez un créneau</h2>
                <p class="text-muted mb-3">Le clic sur un créneau valide immédiatement votre commande.</p>
                <input type="hidden" name="creneauId" id="checkout-creneau-id">

                <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-xl-6 g-3">
                    {% for slot in creneaux %}
                        <div class="col">
                            <button
                                class="card w-100 h-100 border-0 shadow-sm text-start"
                                style="cursor: pointer;"
                                type="button"
                                data-slot-submit
                                data-creneau-id="{{ slot.id }}"
                            >
                                <div class="card-body">
                                    <p class="small text-body-secondary mb-1">{{ slot.dateHeure|date('d/m/Y') }}</p>
                                    <p class="mb-0 fw-semibold">{{ slot.heureDebut|date('H\\hi') }} - {{ slot.heureFin|date('H\\hi') }}</p>
                                </div>
                            </button>
                        </div>
                    {% endfor %}
                </div>
                {% else %}
                <div class="d-grid gap-2">
                    <button class="btn btn-primary btn-lg" type="submit">
                        <i class="bi bi-check-circle me-2"></i>Valider ma commande
                    </button>
                </div>
                {% endif %}
            </form>
        {% endif %}
    </main>

    <script>
        (function () {
            function setupCheckoutForm() {
                const form = document.getElementById('checkout-form');
                const hiddenSlotInput = document.getElementById('checkout-creneau-id');
                if (!form || !hiddenSlotInput || form.dataset.enterGuardSetup === '1') {
                    return;
                }

                form.dataset.enterGuardSetup = '1';

                const slotButtons = form.querySelectorAll('[data-slot-submit]');
                if (slotButtons.length === 0) {
                    return;
                }

                form.addEventListener('keydown', function (event) {
                    const target = event.target;
                    if (
                        event.key === 'Enter' &&
                        !(target instanceof HTMLTextAreaElement) &&
                        !(target instanceof HTMLButtonElement)
                    ) {
                        event.preventDefault();
                    }
                });

                slotButtons.forEach(function (button) {
                    button.addEventListener('click', function () {
                        hiddenSlotInput.value = button.dataset.creneauId ?? '';
                        form.requestSubmit();
                    });
                });
            }

            setupCheckoutForm();
            document.addEventListener('DOMContentLoaded', setupCheckoutForm);
            document.addEventListener('turbo:load', setupCheckoutForm);
        })();
    </script>
{% endblock %}
