{% extends 'base.html.twig' %}

{% block title %}DMAX Inventaire{% endblock %}

{% block body %}
    <main class="container py-4">
        <section class="dmax-list-shell">
            <div class="dmax-list-head">
                <h1>Inventaire DMAX</h1>
                <a class="btn btn-primary" href="{{ path('dmax_produit_new') }}">Nouveau produit</a>
            </div>

            <form method="get" class="dmax-filter-bar">
                <div>
                    <label class="form-label" for="f-q">Recherche</label>
                    <input id="f-q"
                           name="q"
                           type="search"
                           class="form-control"
                           autocomplete="off"
                           value="{{ q }}"
                           placeholder="Titre ou description">
                </div>
                <div>
                    <label class="form-label" for="f-etage">Étage</label>
                    <select id="f-etage" name="etage" class="form-select">
                        <option value="">Tous</option>
                        {% for value in etageOptions %}
                            <option value="{{ value }}" {{ etage == value ? 'selected' : '' }}>{{ value }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label class="form-label" for="f-bureau">Bureau</label>
                    <select id="f-bureau" name="bureau" class="form-select">
                        <option value="">Tous</option>
                        {% for value in bureauOptions %}
                            <option value="{{ value }}" {{ bureau == value ? 'selected' : '' }}>{{ value }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label class="form-label" for="f-vnc">VNC</label>
                    <select id="f-vnc" name="vnc" class="form-select">
                        <option value="">Toutes</option>
                        {% for value in vncOptions %}
                            <option value="{{ value }}" {{ vnc == value ? 'selected' : '' }}>{{ value }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label class="form-label" for="f-teletravailleur">Télétravailleur</label>
                    <select id="f-teletravailleur" name="teletravailleur" class="form-select">
                        <option value="" {{ teletravailleur is null ? 'selected' : '' }}>Tous</option>
                        <option value="1" {{ teletravailleur is same as(true) ? 'selected' : '' }}>Oui</option>
                        <option value="0" {{ teletravailleur is same as(false) ? 'selected' : '' }}>Non</option>
                    </select>
                </div>
                <div>
                    <label class="form-label" for="f-inventaire-etat">Inventaire</label>
                    <select id="f-inventaire-etat" name="inventaireEtat" class="form-select">
                        <option value="" {{ inventaireEtat is null ? 'selected' : '' }}>Tous</option>
                        <option value="sans_numero" {{ inventaireEtat == 'sans_numero' ? 'selected' : '' }}>Sans numéro d'inventaire</option>
                        <option value="non_decompose" {{ inventaireEtat == 'non_decompose' ? 'selected' : '' }}>Inventaire non décomposé</option>
                        <option value="ok" {{ inventaireEtat == 'ok' ? 'selected' : '' }}>Inventaire OK</option>
                    </select>
                </div>
                <div>
                    <label class="form-label" for="f-per-page">Par page</label>
                    <select id="f-per-page" name="perPage" class="form-select" onchange="this.form.submit()">
                        {% for value in [10, 25, 100] %}
                            <option value="{{ value }}" {{ perPage == value ? 'selected' : '' }}>{{ value }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="dmax-filter-actions">
                    <button class="btn btn-primary" type="submit">Filtrer</button>
                    <a class="btn btn-outline-secondary" href="{{ path('dmax_dashboard') }}">Réinitialiser</a>
                </div>
            </form>

            <div class="dmax-list-meta">
                {{ total }} produit{{ total > 1 ? 's' : '' }}
            </div>

            <div class="dmax-table-wrap">
                <table class="dmax-table">
                    <thead>
                        <tr>
                            <th>Miniature</th>
                            <th>Produit</th>
                            <th>Numéro inventaire</th>
                            <th>VNC</th>
                            <th>Télétravailleur</th>
                            <th>Étage / Bureau</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for produit in items %}
                            <tr>
                                <td>
                                    <img class="dmax-thumb" src="{{ asset(produit.photoProduitPublicPath) }}" alt="{{ produit.libelle }}">
                                </td>
                                <td>
                                    <strong>{{ produit.libelle }}</strong><br>
                                    <span class="small text-body-secondary">{{ produit.statut.value }}</span>
                                    {% if produit.description %}
                                        <p class="small text-body-secondary fst-italic mt-1 mb-0">{{ produit.description }}</p>
                                    {% endif %}
                                </td>
                                <td>
                                    {{ produit.numeroInventaire ?: '—' }}
                                    {% if produit.gestion is not null or produit.annee is not null or produit.type is not null or produit.chrono is not null %}
                                        <br>
                                        <small class="text-body-secondary">
                                            {% if produit.gestion is not null %}{{ produit.gestion }}{% endif %}
                                            {% if produit.annee is not null %} • {{ produit.annee }}{% endif %}
                                            {% if produit.type is not null %} • {{ produit.type }}{% endif %}
                                            {% if produit.chrono is not null %} • {{ produit.chrono }}{% endif %}
                                        </small>
                                    {% else %}
                                        <br>
                                        {% if produit.numeroInventaire %}
                                            <small class="text-danger">Non décomposé</small>
                                        {% else %}
                                            <small class="text-danger">Sans numéro d'inventaire</small>
                                        {% endif %}
                                    {% endif %}
                                </td>
                                <td>
                                    {% set vncRaw = produit.vnc|default('')|trim %}
                                    {% if vncRaw == '=0' %}
                                        <span class="badge text-bg-success">{{ vncRaw }}</span>
                                    {% elseif vncRaw == '>0' %}
                                        <span class="badge text-bg-warning">{{ vncRaw }}</span>
                                    {% elseif vncRaw == '??' %}
                                        <span class="badge text-bg-danger">{{ vncRaw }}</span>
                                    {% elseif vncRaw matches '/^-?\\d+(?:[.,]\\d+)?$/' %}
                                        {% set vncNumber = (vncRaw|replace({',':'.'})) + 0 %}
                                        {% if vncNumber == 0 %}
                                            <span class="badge text-bg-success">{{ vncRaw }}</span>
                                        {% elseif vncNumber > 0 %}
                                            <span class="badge text-bg-warning">{{ vncRaw }}</span>
                                        {% else %}
                                            <span class="badge text-bg-danger-inverse">{{ vncRaw }}</span>
                                        {% endif %}
                                    {% else %}
                                        <span class="badge text-bg-danger-inverse">{{ vncRaw != '' ? vncRaw : '—' }}</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <span class="badge {{ produit.tagTeletravailleur ? 'text-bg-success' : 'text-bg-danger' }}">
                                        {{ produit.tagTeletravailleur ? 'Oui' : 'Non' }}
                                    </span>
                                </td>
                                <td>Étage {{ produit.etage }}<br>Bureau {{ produit.porte }}</td>
                                <td>
                                    <div class="dmax-actions dmax-actions-stack">
                                        <a class="btn btn-sm btn-outline-primary" href="{{ path('dmax_produit_edit', {id: produit.id}) }}">Éditer</a>
                                        <form method="post"
                                              action="{{ path('dmax_produit_delete', {id: produit.id}) }}"
                                              onsubmit="return confirm('Confirmer la suppression du produit « {{ produit.libelle|e('js') }} » ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_produit_' ~ produit.id) }}">
                                            <button class="btn btn-sm btn-outline-danger" type="submit">Supprimer</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="7">Aucun produit disponible pour ce filtre.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {% if totalPages > 1 %}
                <nav class="dmax-pager" aria-label="Pagination inventaire">
                    {% set prev = page - 1 %}
                    {% set next = page + 1 %}
                    {% set teletravailleurParam = teletravailleur is same as(true) ? '1' : (teletravailleur is same as(false) ? '0' : '') %}
                    <a class="btn btn-outline-secondary {{ page == 1 ? 'is-disabled' : '' }}"
                       href="{{ page == 1 ? '#' : path('dmax_dashboard', {page: prev, q: q, etage: etage, bureau: bureau, vnc: vnc, teletravailleur: teletravailleurParam, inventaireEtat: inventaireEtat, perPage: perPage}) }}">Précédent</a>

                    <a class="btn {{ page == 1 ? 'btn-primary' : 'btn-outline-secondary' }}"
                       href="{{ path('dmax_dashboard', {page: 1, q: q, etage: etage, bureau: bureau, vnc: vnc, teletravailleur: teletravailleurParam, inventaireEtat: inventaireEtat, perPage: perPage}) }}">1</a>

                    {% set middleStart = page - 2 %}
                    {% if middleStart < 2 %}
                        {% set middleStart = 2 %}
                    {% endif %}
                    {% set middleEnd = page + 2 %}
                    {% if middleEnd > totalPages - 1 %}
                        {% set middleEnd = totalPages - 1 %}
                    {% endif %}

                    {% if middleStart > 2 %}
                        <span class="dmax-pager-ellipsis" aria-hidden="true">…</span>
                    {% endif %}

                    {% if middleStart <= middleEnd %}
                        {% for p in middleStart..middleEnd %}
                            <a class="btn {{ p == page ? 'btn-primary' : 'btn-outline-secondary' }}"
                               href="{{ path('dmax_dashboard', {page: p, q: q, etage: etage, bureau: bureau, vnc: vnc, teletravailleur: teletravailleurParam, inventaireEtat: inventaireEtat, perPage: perPage}) }}">{{ p }}</a>
                        {% endfor %}
                    {% endif %}

                    {% if middleEnd < totalPages - 1 %}
                        <span class="dmax-pager-ellipsis" aria-hidden="true">…</span>
                    {% endif %}

                    <a class="btn {{ page == totalPages ? 'btn-primary' : 'btn-outline-secondary' }}"
                       href="{{ path('dmax_dashboard', {page: totalPages, q: q, etage: etage, bureau: bureau, vnc: vnc, teletravailleur: teletravailleurParam, inventaireEtat: inventaireEtat, perPage: perPage}) }}">{{ totalPages }}</a>

                    <a class="btn btn-outline-secondary {{ page == totalPages ? 'is-disabled' : '' }}"
                       href="{{ page == totalPages ? '#' : path('dmax_dashboard', {page: next, q: q, etage: etage, bureau: bureau, vnc: vnc, teletravailleur: teletravailleurParam, inventaireEtat: inventaireEtat, perPage: perPage}) }}">Suivant</a>
                </nav>
            {% endif %}
        </section>
    </main>
{% endblock %}
