{% extends 'base.html.twig' %}
{% block title %}Administration{% endblock %}
{% block body %}
<main class="container py-4">
    <section class="form-shell dmax-list-shell admin-dashboard-shell">
        <header class="form-head">
            <h1>Administration</h1>
            <p>Pilote l'ouverture de la boutique, les imports et les exports.</p>
        </header>

        <div class="admin-dashboard-grid">
            <section class="form-section admin-dashboard-main">
                <h2>Paramètres boutique</h2>
                <p class="form-help mb-2">Active ou désactive l'ouverture par profil et ajuste le quota.</p>
                {{ form_start(form, {attr: {'class': 'produit-form'}}) }}
                    {{ form_errors(form) }}
                    <div class="form-check">
                        {{ form_widget(form.boutique_ouverte_agents, {'attr': {'class': 'form-check-input'}}) }}
                        {{ form_label(form.boutique_ouverte_agents, 'Ouverte pour les agents', {'label_attr': {'class': 'form-check-label'}}) }}
                    </div>
                    {{ form_errors(form.boutique_ouverte_agents) }}

                    <div class="form-check">
                        {{ form_widget(form.boutique_ouverte_teletravailleurs, {'attr': {'class': 'form-check-input'}}) }}
                        {{ form_label(form.boutique_ouverte_teletravailleurs, 'Ouverte pour les télétravailleurs', {'label_attr': {'class': 'form-check-label'}}) }}
                    </div>
                    {{ form_errors(form.boutique_ouverte_teletravailleurs) }}

                    <div class="form-check">
                        {{ form_widget(form.boutique_ouverte_partenaires, {'attr': {'class': 'form-check-input'}}) }}
                        {{ form_label(form.boutique_ouverte_partenaires, 'Ouverte pour les partenaires', {'label_attr': {'class': 'form-check-label'}}) }}
                    </div>
                    {{ form_errors(form.boutique_ouverte_partenaires) }}

                    <div class="form-check">
                        {{ form_widget(form.mode_tout_doit_disparaitre, {'attr': {'class': 'form-check-input'}}) }}
                        {{ form_label(form.mode_tout_doit_disparaitre, 'Mode Tout doit disparaître', {'label_attr': {'class': 'form-check-label'}}) }}
                    </div>
                    <p class="form-help mb-3">Autorise les agents a repasser commande et complete automatiquement leur commande du prochain samedi quand un creneau existe deja.</p>
                    {{ form_errors(form.mode_tout_doit_disparaitre) }}

                    {{ form_row(form.max_produits_par_commande, {
                        label: 'Quota maximum d\'articles par commande',
                        attr: {'class': 'form-control', 'min': 1}
                    }) }}
                    {{ form_row(form.max_commandes_agents, {
                        label: 'Nombre max de commandes agent',
                        attr: {'class': 'form-control', 'min': 1}
                    }) }}
                    {{ form_row(form.max_commandes_teletravailleurs, {
                        label: 'Nombre max de commandes télétravailleur',
                        attr: {'class': 'form-control', 'min': 1}
                    }) }}

                    <div class="form-actions">
                        <button class="btn btn-primary" type="submit">Sauvegarder</button>
                    </div>
                {{ form_end(form) }}
            </section>

            <section class="form-section">
                <h2>Import télétravailleurs</h2>
                <p class="form-help mb-2">Remplace la liste actuelle des numéros d'agents télétravailleurs depuis un CSV.</p>
                <p class="form-help mb-2">Base active : {{ teletravailleurCount }} agent(s).</p>
                {{ form_start(importForm, {action: path('admin_import_teletravailleurs'), attr: {'class': 'produit-form'}}) }}
                    {{ form_errors(importForm) }}
                    {{ form_row(importForm.csvFile, {
                        label: 'Fichier CSV',
                        attr: {'class': 'form-control'}
                    }) }}
                    <div class="form-actions">
                        <button class="btn btn-primary" type="submit">Importer le CSV</button>
                    </div>
                {{ form_end(importForm) }}
            </section>

            <section class="form-section">
                <h2>Import agents éligibles</h2>
                <p class="form-help mb-2">Remplace la liste blanche actuelle des autres agents depuis un fichier XLSX.</p>
                <p class="form-help mb-2">Base active : {{ agentEligibleCount }} agent(s).</p>
                {{ form_start(agentEligibleImportForm, {action: path('admin_import_agents_eligibles'), attr: {'class': 'produit-form'}}) }}
                    {{ form_errors(agentEligibleImportForm) }}
                    {{ form_row(agentEligibleImportForm.xlsxFile, {
                        label: 'Fichier XLSX',
                        attr: {'class': 'form-control'}
                    }) }}
                    <div class="form-actions">
                        <button class="btn btn-primary" type="submit">Importer le XLSX</button>
                    </div>
                {{ form_end(agentEligibleImportForm) }}
            </section>
        </div>

        <section class="form-section admin-stats-section" data-controller="admin-dashboard-stats-copy">
            <h2>Statistiques commandes</h2>
            <div class="form-actions mb-2" style="justify-content:flex-start;">
                <button
                    type="button"
                    class="btn btn-outline-primary"
                    data-action="admin-dashboard-stats-copy#copy"
                >
                    Copier dans le presse-papier
                </button>
                <span
                    class="form-help mb-0"
                    data-admin-dashboard-stats-copy-target="feedback"
                    aria-live="polite"
                ></span>
            </div>
            <div class="admin-stats-kpis">
                <article class="admin-stats-kpi" data-testid="admin-stat-produits-disponibles">
                    <p class="admin-stats-label">Produits disponibles</p>
                    <p class="admin-stats-value">{{ dashboardStats.totalProduitsDisponibles }}</p>
                </article>
                <article class="admin-stats-kpi" data-testid="admin-stat-produits">
                    <p class="admin-stats-label">Produits commandés</p>
                    <p class="admin-stats-value">{{ dashboardStats.totalProduitsCommandes }}</p>
                </article>
                <article class="admin-stats-kpi" data-testid="admin-stat-commandes">
                    <p class="admin-stats-label">Commandes effectuées</p>
                    <p class="admin-stats-value">{{ dashboardStats.totalCommandesEffectuees }}</p>
                </article>
            </div>

            <div class="admin-stats-days" data-testid="admin-stat-commandes-par-jour">
                <p class="form-help mb-2">Commandes effectuées par jour de livraison</p>
                {% if dashboardStats.commandesEffectueesParJour is empty %}
                    <p class="mb-0">Aucune commande rattachée à un jour de livraison.</p>
                {% else %}
                    <ul class="admin-stats-day-list">
                        {% for row in dashboardStats.commandesEffectueesParJour %}
                            <li class="admin-stats-day-item">
                                <span class="admin-stats-day-date">{{ row.date }}</span>
                                <span class="admin-stats-day-count">{{ row.total }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>

            <textarea
                data-admin-dashboard-stats-copy-target="text"
                hidden
            >Statistiques commandes
Produits disponibles : {{ dashboardStats.totalProduitsDisponibles }}
Produits commandés : {{ dashboardStats.totalProduitsCommandes }}
Commandes effectuées : {{ dashboardStats.totalCommandesEffectuees }}

Commandes effectuées par jour de livraison :
{% if dashboardStats.commandesEffectueesParJour is empty %}
- Aucune commande rattachée à un jour de livraison.
{% else %}
{% for row in dashboardStats.commandesEffectueesParJour %}
- {{ row.date }} : {{ row.total }}
{% endfor %}
{% endif %}</textarea>
        </section>

        <section class="form-section">
            <h2>Exports CDC §13</h2>
            <p class="form-help mb-2">Télécharge les exports ventes, stock restant et comptabilité.</p>
            <div class="form-grid-three">
                <a class="btn btn-outline-primary w-100" href="{{ path('admin_export_ventes', {format: 'csv'}) }}">Ventes (CSV)</a>
                <a class="btn btn-outline-primary w-100" href="{{ path('admin_export_ventes', {format: 'xls'}) }}">Ventes (Excel)</a>
                <a class="btn btn-outline-primary w-100" href="{{ path('admin_export_stock_restant', {format: 'csv'}) }}">Stock restant (CSV)</a>
                <a class="btn btn-outline-primary w-100" href="{{ path('admin_export_stock_restant', {format: 'xls'}) }}">Stock restant (Excel)</a>
                <a class="btn btn-outline-primary w-100" href="{{ path('admin_export_comptabilite', {format: 'csv'}) }}">Comptabilité (CSV)</a>
                <a class="btn btn-outline-primary w-100" href="{{ path('admin_export_comptabilite', {format: 'xls'}) }}">Comptabilité (Excel)</a>
                <a class="btn btn-outline-primary w-100" href="{{ path('admin_export_urssaf') }}">Export URSSAF (Excel)</a>
            </div>
        </section>
    </section>
</main>
{% endblock %}
